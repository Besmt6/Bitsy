# Frontend Environment Variables (Production)
# Copy this to .env in production frontend folder

# ============================================
# BACKEND API URL
# ============================================
# IMPORTANT: Change this to your production domain
# Examples:
# - AWS App Runner: https://xxxxx.us-east-1.awsapprunner.com
# - Custom domain: https://getbitsy.ai
# - EC2: https://api.getbitsy.ai
REACT_APP_BACKEND_URL=https://getbitsy.ai

# ============================================
# NOTES
# ============================================
# - No trailing slash in URL
# - Must use HTTPS in production
# - Backend must have CORS configured for your frontend domain
# - This is the ONLY environment variable needed for frontend
