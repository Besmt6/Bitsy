# Production Environment Configuration
# Copy this to .env in production and fill in your actual values

# ============================================
# DATABASE
# ============================================
# MongoDB Atlas connection string (from Part 1.4 of DEPLOYMENT_AWS.md)
MONGO_URL=mongodb+srv://bitsy-app:YOUR_PASSWORD@bitsy-production.xxxxx.mongodb.net/bitsy?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION
# ============================================
# JWT secret for token signing (MUST be 32+ characters, random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-please-change-this

# ============================================
# AI SERVICES
# ============================================
# OpenAI API key for chat widget (from platform.openai.com)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port for backend server (AWS will map this)
PORT=8001

# Environment mode
NODE_ENV=production

# ============================================
# OPTIONAL: NOTIFICATIONS
# ============================================
# Telegram bot token (optional - for booking notifications)
# Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (where notifications are sent)
TELEGRAM_CHAT_ID=

# ============================================
# OPTIONAL: WEB3/BLOCKCHAIN
# ============================================
# RPC endpoints for blockchain verification (defaults provided by Emergent)
# You can add custom Infura/Alchemy URLs here if needed
ETHEREUM_RPC_URL=https://rpc.emergentmethods.ai/ethereum
POLYGON_RPC_URL=https://rpc.emergentmethods.ai/polygon
BASE_RPC_URL=https://rpc.emergentmethods.ai/base
ARBITRUM_RPC_URL=https://rpc.emergentmethods.ai/arbitrum
OPTIMISM_RPC_URL=https://rpc.emergentmethods.ai/optimism
